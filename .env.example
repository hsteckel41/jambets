# Database (PostgreSQL — Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Next Auth
NEXTAUTH_URL="https://jambets-production.up.railway.app"
NEXTAUTH_SECRET=""   # generate with: openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Setlist.fm API (https://api.setlist.fm)
SETLISTFM_API_KEY=""

# Cron job auth secret — used to protect /api/cron/* routes
# generate with: openssl rand -base64 32
CRON_SECRET=""
